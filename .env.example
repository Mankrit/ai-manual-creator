# ==============================================================================
# Environment Variables Example
# Copy this file, create a new file and save as '.env' and fill in your API keys there.
# ==============================================================================

# --- Google Gemini ---
# GEMINI_API_KEY="AIzaSy..."

# --- Anthropic Claude ---
# ANTHROPIC_API_KEY="sk-ant-..."

# --- OpenAI or OpenAI-Compatible Custom Proxies (OpenRouter, DeepSeek, etc.) ---
# OPENAI_API_KEY="your-key-here"
# OPENAI_API_BASE="https://openrouter.ai/api/v1" # Optional, only if using proxy
